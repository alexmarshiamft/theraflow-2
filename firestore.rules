rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isRole('admin');
    }

    function isClinician() {
      return isRole('clinician') || isAdmin();
    }

    // 1. Users Collection
    match /users/{userId} {
      // Users can read their own profile, Clinicians/Admins can read all
      allow read: if isUser(userId) || isClinician();
      // Users can update their own non-role fields
      allow update: if isUser(userId) 
        && (!request.resource.data.keys().hasAny(['role', 'permissions']) 
            || request.resource.data.role == resource.data.role);
      allow create: if isUser(userId);
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // 2. Patients / Clients (PHI Data)
    match /clients/{clientId} {
      allow read: if resource.data.userId == request.auth.uid || isClinician();
      allow create: if request.resource.data.userId == request.auth.uid || isClinician();
      allow update: if resource.data.userId == request.auth.uid || isClinician();
      allow delete: if isAdmin();
    }

    // 3. Clinical Notes & Records (Strict PHI)
    match /clinicalNotes/{noteId} {
      allow read: if resource.data.userId == request.auth.uid || isClinician();
      allow write: if resource.data.userId == request.auth.uid || isClinician();
      allow create: if request.resource.data.userId == request.auth.uid || isClinician();
    }

    match /appointments/{appointmentId} {
      allow read, write: if resource.data.userId == request.auth.uid || isClinician();
      allow create: if request.resource.data.userId == request.auth.uid || isClinician();
    }

    match /claims/{claimId} {
      allow read, write: if resource.data.userId == request.auth.uid || isClinician();
      allow create: if request.resource.data.userId == request.auth.uid || isClinician();
    }

    // 4. Financial / Billing & Payroll
    match /transactions/{txId} {
      // Patients can see their own payments
      allow read: if isUser(resource.data.userId) || isClinician();
      // System/Clinicians process transactions
      allow create: if isClinician() || isUser(request.resource.data.userId);
      allow update: if isClinician();
      // Transactions are immutable once finalized (only soft deletes/voids via update)
      allow delete: if false; 
    }

    match /payrollRuns/{logId} {
      // Only admins and the specific clinician can see their payroll
      allow read: if isAdmin() || isUser(resource.data.clinicianId);
      allow create, update: if isAdmin();
      allow delete: if false; // Payroll logs must be immutable
    }

    // 5. Audit Logs & Webhooks
    match /auditLogs/{logId} {
      allow read: if resource.data.userId == request.auth.uid || isClinician();
      allow create: if isAuthenticated(); 
      allow update, delete: if false; // IMMUTABLE
    }
    
    match /webhookLogs/{logId} {
      allow read: if resource.data.userId == request.auth.uid || isAdmin();
      allow create: if true; // Webhooks bypass auth rules
      allow update, delete: if false;
    }
    
    // Employees
    match /employees/{employeeId} {
      allow read: if isClinician();
      allow write: if isAdmin();
    }

    // 6. Secure Messaging
    match /messages/{messageId} {
      // Users can read messages where they are the sender or in the recipient list
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        request.auth.uid in resource.data.participantIds
      );
      // Users can send messages
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}